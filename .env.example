# Cockpit + Phase J + Phase K (auto-trader) environment template.
# Copy to .env (which is gitignored) and fill in real values.

# ── Obsidian vault (where Markdown + the HTML dashboard are rendered) ───────
# Point this at your own Obsidian vault's Investment_AI folder. Typically a
# cloud-synced mount (Google Drive / iCloud / Dropbox). If unset, the code
# defaults to ~/Obsidian/Investment_AI. The volatile "My Drive"/"My Drive 2"
# suffix some Drive clients flip is auto-healed — don't worry about it.
# VAULT_PATH=/path/to/your/Obsidian/Investment_AI

# ── Cockpit (existing) ──────────────────────────────────────────────────────
# ALPHA_VANTAGE_API_KEY is no longer used (yfinance replaces it).
WATCHLIST=AAPL,MSFT,NVDA,GOOGL,META,JPM,JNJ,KO,XOM,WMT,SPY,QQQ
LOG_LEVEL=INFO
DB_PATH=db/cockpit.sqlite

# Cockpit auth (Fly only; local server defaults to no auth when unset)
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASS=playfish

# ── Phase K — Auto-trader: trading mode ────────────────────────────────────
TRADING_MODE=paper                # "paper" | "live" — MUST be explicit

# Use the local mock broker (default for the build). Flip to false when
# real Alpaca paper keys are wired in.
ALPACA_USE_MOCK=true

# ── Alpaca paper keys (only when ALPACA_USE_MOCK=false) ────────────────────
ALPACA_API_KEY=mock
ALPACA_SECRET_KEY=mock
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Alpaca live keys (DO NOT POPULATE until 3-month paper gate clears) ─────
# ALPACA_API_KEY_LIVE=
# ALPACA_SECRET_KEY_LIVE=
# ALPACA_BASE_URL_LIVE=https://api.alpaca.markets
# LIVE_TRADING_CONFIRMED=YES_I_UNDERSTAND_REAL_MONEY

# ── Auto-trader paths (override only if you know what you're doing) ────────
# Auto-trader's own SQLite (separate from cockpit's `db/cockpit.sqlite`):
TRADER_DB_PATH=auto_trader/state/portfolio.db
SCREENER_CACHE_PATH=auto_trader/state/screener_cache.json

# ── Alerts (cred-optional — auto_trader works without these) ───────────────
# macOS notifications are ON by default on Macs; set false to silence.
# ALERT_MACOS=true
# Phone push via ntfy.sh (free, no account): pick a LONG RANDOM topic name
# (the topic is the credential — anyone who knows it can read the alerts),
# subscribe to it in the ntfy mobile app, then set it here. Unset = disabled,
# nothing leaves the machine.
# NTFY_TOPIC=qt-alerts-CHANGE-ME-a8f3k2m9x7
# ALERT_EMAIL_FROM=you@gmail.com
# ALERT_EMAIL_TO=you@gmail.com
# SMTP_PASSWORD=your_gmail_app_password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USE_SSL=true
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Paper-trade gate (override only for testing) ───────────────────────────
# PAPER_TRADE_MIN_MONTHS=3
# REQUIRE_PAPER_BEFORE_LIVE=true
